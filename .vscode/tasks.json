        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "group": "dev-servers"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Frontend Dev",
      "type": "process",
      "command": "powershell",
