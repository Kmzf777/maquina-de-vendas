# Environment files — never bake local secrets into the image
.env
.env.local
.env.*.local
*.env

# Dev/test artifacts
.pytest_cache/
tests/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# IDE/editor
.vscode/
.idea/

# Docs/scripts not needed at runtime
scripts/

# Dev-only compose override (publica porta do Redis no host) — nunca na imagem/prod
docker-compose.override.yml
